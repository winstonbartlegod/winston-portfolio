# ── Site URL (used for Open Graph & sitemap) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.netlify.app

# ── Contact Form ──────────────────────────────────────────────────
# Option A: Netlify Forms (no extra config needed — it's handled via HTML attribute)
# Option B: Formspree — create a free form at https://formspree.io and paste the ID below
NEXT_PUBLIC_FORMSPREE_ID=

# ── Analytics (optional) ──────────────────────────────────────────
# Plausible (privacy-friendly): https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=
